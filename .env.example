# Bybit API (free — create at https://www.bybit.com, permissions: Read + Derivatives Trade, NO withdraw)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# Trading params
QUOTE_CURRENCY=USDT
UNIVERSE_SIZE=50
TIMEFRAME=1h
CYCLE_SECONDS=300

# Risk hard caps
MAX_RISK_PCT_PER_TRADE=2.0
MAX_CONCURRENT_POSITIONS=5
MAX_LEVERAGE=3
DAILY_LOSS_HALT_PCT=5.0
MAX_DRAWDOWN_KILL_PCT=15.0
SL_COOLDOWN_HOURS=4
FUNDING_RATE_GATE=0.001
LIVE_SIZE_CAP_PCT=0.25

# Execution mode
MODE=paper  # paper | live

# Claude brain (gh copilot CLI)
GH_COPILOT_BIN=gh
CLAUDE_MODEL=claude-opus-4.7
CLAUDE_TIMEOUT_SECONDS=60

# News
NEWSAPI_KEY=
CRYPTOPANIC_TOKEN=
NEWS_CACHE_MINUTES=15

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Storage
DB_PATH=./data/bot.sqlite

# Logging
LOG_LEVEL=INFO
LOG_DIR=./logs
